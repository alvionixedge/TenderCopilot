{
  "name": "tendercopilot-ai",
  "version": "0.1.0",
  "private": true,
  "description": "TenderCopilot AI — AI-powered procurement & bid management platform",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/migrate.mjs && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.0",
    "docx": "^9.0.0",
    "drizzle-orm": "^0.44.0",
    "lucide-react": "^0.525.0",
    "next": "^15.3.0",
    "next-auth": "5.0.0-beta.29",
    "node-html-parser": "^7.1.0",
    "openai": "^4.100.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
