# =============================================================================
# TenderCopilot AI — Environment Variables
# Section 7.6 of the technical specification.
# Every running environment (production, preview) is configured in Vercel's
# environment-variable store. This file is a template; never commit real values.
# =============================================================================

# --- Application URL ---------------------------------------------------------
# Production: https://tendercopilot.ai (or your custom domain)
# Preview:    https://<branch>-<project>.vercel.app
NEXT_PUBLIC_APP_URL="https://tendercopilot.ai"
NEXT_PUBLIC_APP_NAME="TenderCopilot AI"

# --- Database (Neon serverless PostgreSQL) -----------------------------------
# Production points at the primary Neon branch.
# Preview deployments are auto-attached to per-PR Neon branches.
DATABASE_URL="postgresql://user:pass@ep-xxxxx.region.aws.neon.tech/tendercopilot?sslmode=require"
DATABASE_POOL_URL="postgresql://user:pass@ep-xxxxx-pooler.region.aws.neon.tech/tendercopilot?sslmode=require"

# --- NextAuth (Auth.js) ------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Microsoft Entra ID / Azure AD
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/common/v2.0"

# --- AI providers (server-only) ----------------------------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5"
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- Object storage (Cloudflare R2, S3-compatible) ---------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_DOCUMENTS="tendercopilot-documents"
R2_BUCKET_QUARANTINE="tendercopilot-quarantine"
R2_PUBLIC_URL="https://<account-id>.r2.cloudflarestorage.com"

# --- Async / queue (Upstash) -------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# --- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="TenderCopilot AI <noreply@tendercopilot.ai>"

# --- Payments (Razorpay) -----------------------------------------------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# --- Observability -----------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# --- Cron / scheduled jobs ---------------------------------------------------
# Token Vercel Cron sends as Authorization: Bearer <token>
CRON_SECRET=""
